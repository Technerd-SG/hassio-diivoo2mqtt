void executeInitSequence() {
  Serial.println("Starte Register-Initialisierung...");

  // Soft Reset bewusst separat mit Delay
  writeRegister(0x7F, 0xFF);
  delay(30);

  for (size_t i = 0; i < (sizeof(INIT_SEQUENCE) / sizeof(INIT_SEQUENCE[0])); i++) {
    writeRegister(INIT_SEQUENCE[i].addr, INIT_SEQUENCE[i].value);
  }
}
